# Production environment template — fill in real values on your host (never commit secrets).

# --- Core ---
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_STRONG_RANDOM
# Managed Postgres URL (Render/Railway provide this). SQLAlchemy accepts postgresql://
DATABASE_URL=postgresql://user:password@host:5432/cuisine
# Comma-separated allowed frontend origins (NO trailing slash)
CORS_ORIGINS=https://your-frontend.example.com
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=20160
WEB_CONCURRENCY=2
LOG_LEVEL=INFO

# --- Redis / Celery ---
CELERY_BROKER_URL=redis://host:6379/0
CELERY_RESULT_BACKEND=redis://host:6379/0

# --- Object storage (S3-compatible: AWS S3, Cloudflare R2, Backblaze B2...) ---
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_PUBLIC_ENDPOINT=https://<your-public-bucket-domain>
S3_BUCKET=cuisine-prod
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
S3_REGION=auto

# --- OCR ---
OCR_PROVIDER_CHAIN=mistral,google
# In production, set to false so OCR failures surface instead of returning sample data
OCR_ALLOW_STUB_FALLBACK=false
MISTRAL_API_KEY=
# Google Document AI (optional)
GCP_PROJECT_ID=
DOCAI_LOCATION=eu
DOCAI_PROCESSOR_ID=
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp.json

# --- Frontend (build-time) ---
# Must point to the deployed backend, including /api/v1
NEXT_PUBLIC_API_URL=https://your-backend.example.com/api/v1
