# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=cuisine
DATABASE_URL=postgresql+psycopg2://postgres:password@postgres:5432/cuisine

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# JWT secret + token lifetimes (minutes)
SECRET_KEY=change_me_for_prod
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=20160

# CORS (comma-separated allowed origins for the frontend)
CORS_ORIGINS=http://localhost:3000

# MinIO (S3 compatible)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
S3_ENDPOINT=http://minio:9000
S3_BUCKET=cuisine-dev
# Browser-reachable endpoint for presigned download URLs (host-published MinIO)
S3_PUBLIC_ENDPOINT=http://localhost:9000

# --- OCR ------------------------------------------------------------------
# Provider fallback order. In production use "mistral,google".
OCR_PROVIDER_CHAIN=mistral,google
# When true (dev), a deterministic stub serves sample data if no real provider
# is configured/working. Set to false in production so failures surface to users.
OCR_ALLOW_STUB_FALLBACK=true
# Resilience tuning
OCR_TIMEOUT_SECONDS=30
OCR_MAX_RETRIES=2
OCR_RETRY_BACKOFF=0.5
OCR_CB_FAIL_THRESHOLD=3
OCR_CB_RESET_SECONDS=30
LOG_LEVEL=INFO

# Mistral OCR
MISTRAL_API_KEY=
MISTRAL_OCR_URL=https://api.mistral.ai/v1/ocr
MISTRAL_OCR_MODEL=mistral-ocr-latest

# Google Document AI (Invoice processor)
GCP_PROJECT_ID=
DOCAI_LOCATION=eu
DOCAI_PROCESSOR_ID=
DOCAI_PROCESSOR_VERSION=
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- AI assistant (Claude / Anthropic) ------------------------------------
# Required to enable the AI assistant; without it /api/v1/ai/chat returns 503.
ANTHROPIC_API_KEY=
# Optional tuning
AI_MODEL=claude-opus-4-8
AI_MAX_TOKENS=4096
AI_EFFORT=medium
AI_MAX_TOOL_ITERATIONS=8

# --- Video import (transcript → recipe) -----------------------------------
# YouTube uses captions (no key). Other platforms (TikTok/Insta/FB) download
# audio (yt-dlp+ffmpeg) and transcribe via STT — requires OPENAI_API_KEY.
OPENAI_API_KEY=
VIDEO_STT_PROVIDER=openai
VIDEO_STT_MODEL=whisper-1
VIDEO_YT_CAPTION_LANGS=fr,en
VIDEO_ALLOW_AUDIO_STT=true
VIDEO_MAX_DURATION_SECONDS=1800

# --- Monitoring (Grafana) -------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
