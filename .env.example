# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=cuisine
DATABASE_URL=postgresql+psycopg2://postgres:password@postgres:5432/cuisine

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# JWT secret + token lifetimes (minutes)
# REQUIRED — the backend refuses to start if this is empty or a placeholder.
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=20160

# Brute-force protection on POST /auth/token (defaults shown; tune only if needed).
# Counters live in Redis when REDIS_URL/CELERY_BROKER_URL is reachable, so a
# lockout holds across workers; otherwise they are per-process.
# LOGIN_FREE_ATTEMPTS=4            # bad passwords allowed per account before locking
# LOGIN_IP_FREE_ATTEMPTS=20        # bad passwords allowed per IP (credential stuffing)
# LOGIN_BASE_LOCK_SECONDS=30       # first lockout; doubles with each further failure
# LOGIN_MAX_LOCK_SECONDS=900       # lockout ceiling (15 min)
# LOGIN_FAILURE_WINDOW_SECONDS=900 # how long a failure is remembered

# CORS (comma-separated allowed origins for the frontend)
CORS_ORIGINS=http://localhost:3000

# MinIO (S3 compatible)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
S3_ENDPOINT=http://minio:9000
S3_BUCKET=cuisine-dev
# Browser-reachable endpoint for presigned download URLs (host-published MinIO)
S3_PUBLIC_ENDPOINT=http://localhost:9000

# --- OCR ------------------------------------------------------------------
# Provider fallback order. In production use "mistral,google".
OCR_PROVIDER_CHAIN=mistral,google
# LOCAL DEMOS ONLY. When true, a canned sample invoice is returned if no OCR
# provider is configured/working. NEVER enable this in production: the fake
# lines get priced, written to the purchase ledger and propagated into recipe
# costs, silently corrupting real numbers. The code now defaults to false.
OCR_ALLOW_STUB_FALLBACK=true
# Resilience tuning
OCR_TIMEOUT_SECONDS=30
OCR_MAX_RETRIES=2
OCR_RETRY_BACKOFF=0.5
OCR_CB_FAIL_THRESHOLD=3
OCR_CB_RESET_SECONDS=30
LOG_LEVEL=INFO

# Mistral OCR
MISTRAL_API_KEY=
MISTRAL_OCR_URL=https://api.mistral.ai/v1/ocr
MISTRAL_OCR_MODEL=mistral-ocr-latest

# Google Document AI (Invoice processor)
GCP_PROJECT_ID=
DOCAI_LOCATION=eu
DOCAI_PROCESSOR_ID=
DOCAI_PROCESSOR_VERSION=
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- AI assistant (Claude / Anthropic) ------------------------------------
# Required to enable the AI assistant; without it /api/v1/ai/chat returns 503.
ANTHROPIC_API_KEY=
# Optional tuning
AI_MODEL=claude-opus-4-8
AI_MAX_TOKENS=4096
AI_EFFORT=medium
AI_MAX_TOOL_ITERATIONS=8

# --- Video import (transcript → recipe) -----------------------------------
# YouTube uses captions (no key). Other platforms (TikTok/Insta/FB) download
# audio (yt-dlp+ffmpeg) and transcribe via STT — requires OPENAI_API_KEY.
OPENAI_API_KEY=
VIDEO_STT_PROVIDER=openai
VIDEO_STT_MODEL=whisper-1
VIDEO_YT_CAPTION_LANGS=fr,en
VIDEO_ALLOW_AUDIO_STT=true
VIDEO_MAX_DURATION_SECONDS=1800

# --- Monitoring (Grafana) -------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# --- Phase 2 : durcissement (valeurs par défaut affichées) -------------------
# Quotas par tenant, par minute, sur les routes qui coûtent de l'argent (LLM,
# OCR) ou du CPU. Sans eux, un seul compte peut vider ton budget Anthropic.
# AI_CHAT_PER_MIN=30
# OCR_PER_MIN=20              # /invoices/upload|ingest|ingest-async|extract
# PDF_IMPORT_PER_MIN=10
# VIDEO_IMPORT_PER_MIN=10
# PRODUCT_MATCH_PER_MIN=60
#
# Plafonds QUOTIDIENS. Le plafond par minute borne une rafale, pas une facture :
# a 30 appels IA/min, un tenant pourrait faire 43 200 appels/jour, soit ~970 $
# d'Anthropic pour un seul client en une journee. C'est le plafond quotidien qui
# borne reellement la depense (et c'est la seule chose entre un jeton vole et
# ton budget).
# AI_CHAT_PER_DAY=300          # ~7 $/jour/client au maximum
# OCR_PER_DAY=400
# PDF_IMPORT_PER_DAY=100
# VIDEO_IMPORT_PER_DAY=50
#
# Pool de connexions PostgreSQL (budget : (POOL_SIZE + MAX_OVERFLOW) x workers)
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT_SECONDS=10
# DB_POOL_RECYCLE_SECONDS=1800

# Taille maximale d'un document envoyé (facture, recette PDF/photo), en Mo.
# MAX_UPLOAD_MB=20

# SSRF : par défaut, l'import vidéo n'accepte QUE les plateformes supportées
# (YouTube, TikTok, Instagram, Facebook, Vimeo, Dailymotion). Passer à true
# ouvre à n'importe quel hôte — le blocage des adresses internes (127.0.0.1,
# 10.x, 169.254.169.254...) reste actif dans tous les cas.
# VIDEO_ALLOW_ANY_HOST=false
