.dart_tool/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
pubspec.lock
*.iml
.idea/

# Generated native folders (run `flutter create .` to regenerate)
android/
ios/
web/
windows/
linux/
macos/
.metadata

# EXCEPTIONS — two generated files are force-added to git (`git add -f`) because
# they carry fixes that must survive a `flutter create` regeneration (which
# never overwrites an existing file):
#   android/app/src/main/AndroidManifest.xml  -> INTERNET permission, without
#       which every API call fails in a release build.
#   android/app/build.gradle.kts              -> compileSdk 36, without which
#       file_picker's transitive deps refuse to build a release APK.
# Do NOT track android/local.properties: it holds a machine-specific SDK path.
